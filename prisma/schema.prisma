generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Usuario {
  id            Int      @id @default(autoincrement())
  nome          String
  email         String   @unique
  senha         String
  telefone      String
  cpf           String   @unique
  eAdmin        Boolean  @default(false) @map("e_admin")
  isActive      Boolean  @default(true) @map("is_active")
  dtCriacao     DateTime @default(now()) @map("dt_criacao")
  dtAtualizacao DateTime @updatedAt @map("dt_atualizacao")
  idEndereco    Int      @map("id_endereco")

  endereco Endereco @relation(fields: [idEndereco], references: [id])
  reservas Reserva[]

  @@map("usuarios")
}

model Reserva {
  id        Int           @id @default(autoincrement())
  dia       DateTime      @db.Date
  turno     Turno
  status    StatusReserva @default(confirmada)
  dtCriacao DateTime      @default(now()) @map("dt_criacao")
  idUsuario Int           @map("id_usuario")
  idSala    Int           @map("id_sala")

  usuario Usuario @relation(fields: [idUsuario], references: [id])
  sala    Sala    @relation(fields: [idSala], references: [id])

  @@map("reservas")
}

enum Turno {
  M
  T
  N
}

enum StatusReserva {
  confirmada
  cancelada
}

model Sala {
  id            Int      @id @default(autoincrement())
  nome          String   @unique
  capacidade    Int
  descricao     String?
  precoLocacao  Float    @map("preco_locacao")
  isActive      Boolean  @default(true) @map("is_active")
  dtCriacao     DateTime @default(now()) @map("dt_criacao")
  dtAtualizacao DateTime @updatedAt @map("dt_atualizacao")

  reservas Reserva[]

  @@map("salas")
}

model Endereco {
  id          Int     @id @default(autoincrement())
  rua         String
  numero      String
  complemento String?
  bairro      String
  cep         String
  cidade      String
  uf          String

  usuarios Usuario[]

  @@map("enderecos")
}
